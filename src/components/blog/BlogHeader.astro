---
import Container from '../ui/Container.astro';
---

<section class="border-b border-line bg-surface">
  <Container class="grid items-center gap-10 py-14 md:py-20 lg:grid-cols-[1.15fr_0.85fr] lg:gap-16">
    <div>
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-dark">Le blog Keenton</p>
      <h1 class="mt-5 max-w-3xl text-4xl font-bold text-ink md:text-5xl">
        Analyses et retours d’expérience
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-secondary">
        Cloud, cybersécurité, DevOps, automatisation et environnement de travail : des contenus
        concrets pour comprendre les choix techniques et leurs conséquences opérationnelles.
      </p>
    </div>

    <div
      class="flex min-h-48 items-center justify-center rounded-xl border border-dashed border-line bg-surface-alt md:min-h-56"
      aria-label="Emplacement réservé à la future illustration du blog"
    >
      <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-ink-secondary/70">
        Illustration à venir
      </span>
    </div>
  </Container>
</section>
