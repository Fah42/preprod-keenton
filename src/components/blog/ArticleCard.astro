---
import { formatPostDate, getExpertiseForPost } from '../../lib/blog.js';

const { post } = Astro.props;
const { title, description, date, category } = post.data;
const expertise = getExpertiseForPost(post);
const formattedDate = formatPostDate(date);
---

<a
	href={`/blog/${post.id}`}
	style={`--post-accent: ${expertise?.accentColor ?? '#29aae3'}`}
	class="blog-card group relative flex h-full flex-col overflow-hidden rounded-lg border border-line p-8 transition-all duration-200 hover:-translate-y-1"
>
	<div class="blog-card__rail absolute inset-y-0 left-0 w-[3px]"></div>
	<div class="blog-card__topline absolute inset-x-0 top-0 h-[2px]" aria-hidden="true"></div>
	<p class="relative flex flex-wrap items-center gap-3 font-mono text-xs font-medium uppercase tracking-[0.12em] text-accent-dark">
		<span>{category}</span>
		<span class="text-ink-secondary/60 normal-case tracking-normal">{formattedDate}</span>
	</p>
	<h3 class="blog-card__title relative mt-4 text-xl leading-snug font-semibold text-ink">{title}</h3>
	<p class="mt-3 grow text-base leading-relaxed text-ink-secondary">{description}</p>
	<p class="blog-card__cta mt-6 inline-flex items-center gap-2 text-sm font-medium">
		Lire l'article
		<span class="transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true">&rarr;</span>
	</p>
</a>

<style>
	.blog-card {
		background: var(--color-surface);
		border-color: var(--color-line);
		box-shadow: var(--shadow-cold);
	}

	.blog-card__rail {
		background: var(--color-line);
		transition: background-color 200ms ease;
	}

	/* Filet superieur qui se deploie au survol, teinte a l'accent du billet. */
	.blog-card__topline {
		background: linear-gradient(90deg, var(--post-accent), color-mix(in srgb, var(--post-accent) 35%, white));
		transform: scaleX(0);
		transform-origin: left;
		transition: transform 250ms ease;
	}

	.blog-card:hover .blog-card__topline {
		transform: scaleX(1);
	}

	.blog-card__title,
	.blog-card__cta {
		transition: color 200ms ease;
	}

	.blog-card__cta {
		color: var(--color-ink-secondary);
	}

	.blog-card:hover {
		border-color: var(--post-accent);
		background: color-mix(in srgb, var(--post-accent) 5%, var(--color-surface));
		box-shadow: 0 18px 34px color-mix(in srgb, var(--post-accent) 8%, transparent);
	}

	.blog-card:hover .blog-card__rail {
		background: var(--post-accent);
	}

	.blog-card:hover .blog-card__title,
	.blog-card:hover .blog-card__cta {
		color: var(--post-accent);
	}
</style>
