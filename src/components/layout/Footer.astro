---
import Container from '../ui/Container.astro';
import { site, expertises } from '../../data/site.js';

const year = new Date().getFullYear();

const blogTopics = [
	{ label: 'Cloud hybride', href: '/blog/migrer-cloud-hybride', accent: '#1565C0', size: 'lg', x: 24, y: 10 },
	{ label: 'Sauvegarde & PRA', href: '/blog/sauvegarde-3-2-1', accent: '#1565C0', size: 'sm', x: 76, y: 10 },
	{ label: 'Kubernetes & GitOps', href: '/blog/kubecon-amsterdam-2026', accent: '#B87333', size: 'md', x: 33, y: 32 },
	{ label: 'CI/CD', href: '/blog/cicd-industrialiser-deploiements', accent: '#B87333', size: 'sm', x: 79, y: 32 },
	{ label: 'Agents IA', href: '/blog/agents-ia-sans-perdre-controle', accent: '#6F2DBD', size: 'sm', x: 24, y: 54 },
	{ label: 'IA souveraine', href: '/blog/gero-ia-souveraine', accent: '#6F2DBD', size: 'md', x: 70, y: 54 },
	{ label: 'Cybersécurité', href: '/blog/signaux-attaque', accent: '#DC2626', size: 'sm', x: 22, y: 76 },
	{ label: 'Infogérance 24/7', href: '/blog/infogerance-24-7', accent: '#E6A700', size: 'md', x: 75, y: 76 },
	{ label: 'Microsoft 365', href: '/blog/copilot-microsoft-365', accent: '#00A4EF', size: 'sm', x: 50, y: 95 },
];
---

<footer transition:persist="site-footer" class="relative bg-linear-to-b from-footer-from to-footer-to text-white">
	<div class="hairline-aurora absolute inset-x-0 top-0 h-px" aria-hidden="true"></div>
	<Container class="py-10 md:py-12">
		<div class="grid gap-8 md:grid-cols-2 xl:grid-cols-[1.15fr_0.95fr_0.65fr_1.35fr] xl:gap-7">
			<div>
				<img
					src="/images/logo-keenton-full-white.png"
					alt="Keenton"
					class="h-7 w-auto"
					width="221"
					height="43"
				/>
				<p class="mt-3 max-w-xs text-sm text-white/75">
					{site.baseline}. Nous concevons, déployons et maintenons des
					infrastructures adaptées à vos usages.
				</p>
				<p class="mt-6 font-mono text-xs uppercase tracking-[0.2em] text-white/60">
					{site.location}
				</p>
			</div>

			<nav aria-label="Expertises">
				<p class="font-mono text-xs uppercase tracking-[0.2em] text-white">Expertises</p>
				<ul class="mt-4 space-y-2.5">
					{
						expertises.map((expertise) => (
							<li>
								<a href={expertise.href} class="text-sm text-white/85 transition-colors hover:text-white">
									{expertise.title}
								</a>
							</li>
						))
					}
				</ul>
			</nav>

			<nav aria-label="Navigation secondaire">
				<p class="font-mono text-xs uppercase tracking-[0.2em] text-white">Keenton</p>
				<ul class="mt-4 space-y-2.5">
					<li><a href="/" class="text-sm text-white/85 transition-colors hover:text-white">Accueil</a></li>
					<li><a href="/blog" class="text-sm text-white/85 transition-colors hover:text-white">Blog</a></li>
					<li><a href="/contact" class="text-sm text-white/85 transition-colors hover:text-white">Contact</a></li>
				</ul>
			</nav>

			<section class="w-full max-w-[23rem] justify-self-center md:justify-self-end" aria-labelledby="footer-topics-title">
				<h2 id="footer-topics-title" class="font-mono text-xs font-normal uppercase tracking-[0.2em] text-white">
					Explorer nos sujets
				</h2>

				<div class="footer-topics relative mt-4 h-[14.5rem] overflow-hidden p-3">
					<ul class="footer-topic-cloud relative z-10 h-full" aria-label="Sujets du blog">
						{
							blogTopics.map((topic) => (
								<li
									class="footer-topic__item"
									style={`--topic-accent: ${topic.accent}; --topic-x: ${topic.x}%; --topic-y: ${topic.y}%`}
								>
									<a href={topic.href} class:list={['footer-topic group', `footer-topic--${topic.size}`]}>
										<span class="footer-topic__shine" aria-hidden="true"></span>
										<span class="footer-topic__dot" aria-hidden="true"></span>
										<span class="relative">{topic.label}</span>
										<span class="footer-topic__arrow relative" aria-hidden="true">↗</span>
									</a>
								</li>
							))
						}
					</ul>
				</div>
			</section>
		</div>

		<div class="mt-8 flex flex-col gap-3 border-t border-white/15 pt-5 text-xs text-white/60 md:flex-row md:items-center md:justify-between">
			<p>© {year} {site.name}. Tous droits réservés.</p>
			<a href="/mentions-legales" class="transition-colors hover:text-white">Mentions légales</a>
		</div>
	</Container>
</footer>

<style>
	.footer-topic__item {
		position: absolute;
		left: var(--topic-x);
		top: var(--topic-y);
		transform: translate(-50%, -50%);
	}

	.footer-topic {
		position: relative;
		display: inline-flex;
		align-items: center;
		gap: 0.38rem;
		white-space: nowrap;
		overflow: hidden;
		border: 1px solid color-mix(in srgb, var(--topic-accent) 42%, rgb(255 255 255 / 0.12));
		border-radius: 9999px;
		background: linear-gradient(145deg, color-mix(in srgb, var(--topic-accent) 10%, transparent), rgb(255 255 255 / 0.025));
		color: white;
		font-weight: 600;
		letter-spacing: -0.01em;
		box-shadow: none;
		filter: none;
		text-shadow: none;
		transition: color 220ms ease, border-color 220ms ease, background 220ms ease;
	}

	.footer-topic--sm {
		padding: 0.38rem 0.58rem;
		font-size: 0.6875rem;
	}

	.footer-topic--md {
		padding: 0.43rem 0.66rem;
		font-size: 0.75rem;
	}

	.footer-topic--lg {
		padding: 0.47rem 0.72rem;
		font-size: 0.8125rem;
	}

	.footer-topic__shine {
		position: absolute;
		inset: 0;
		background: linear-gradient(105deg, transparent 24%, color-mix(in srgb, var(--topic-accent) 36%, white) 48%, transparent 70%);
		opacity: 0;
		transform: translateX(-125%);
		transition: transform 560ms ease, opacity 220ms ease;
	}

	.footer-topic__dot {
		position: relative;
		width: 0.34rem;
		height: 0.34rem;
		flex: none;
		border-radius: 9999px;
		background: var(--topic-accent);
		box-shadow: 0 0 0 2px color-mix(in srgb, var(--topic-accent) 12%, transparent);
	}

	.footer-topic__arrow {
		opacity: 0.45;
		transition: opacity 220ms ease, transform 220ms ease;
	}

	.footer-topic:hover,
	.footer-topic:focus-visible {
		border-color: color-mix(in srgb, var(--topic-accent) 82%, white);
		background: linear-gradient(145deg, color-mix(in srgb, var(--topic-accent) 20%, transparent), rgb(255 255 255 / 0.055));
		color: white;
		box-shadow: none;
	}

	.footer-topic:focus-visible {
		outline: 2px solid var(--topic-accent);
		outline-offset: 3px;
	}

	.footer-topic:hover .footer-topic__shine,
	.footer-topic:focus-visible .footer-topic__shine {
		opacity: 0.55;
		transform: translateX(125%);
	}

	.footer-topic:hover .footer-topic__arrow,
	.footer-topic:focus-visible .footer-topic__arrow {
		opacity: 1;
		transform: translate(0.1rem, -0.1rem);
	}

	@media (prefers-reduced-motion: reduce) {
		.footer-topic,
		.footer-topic__shine,
		.footer-topic__arrow {
			transition-duration: 0.01ms;
		}
	}
</style>
