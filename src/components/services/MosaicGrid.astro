---
import Container from '../ui/Container.astro';
import Icon from '../ui/Icon.astro';

const { eyebrow, title, body, items = [], layout } = Astro.props;
const gridLayout = layout === 'four' ? 'xl:grid-cols-4' : layout === 'six' ? 'xl:grid-cols-3' : 'md:grid-cols-2';
const compactCards = layout === 'four' || layout === 'six';
---

<section class="bg-surface-alt py-16 md:py-24">
	<Container>
		<header class="max-w-5xl">
			{eyebrow && <h2 class="font-mono text-3xl font-semibold tracking-[-0.04em] text-[var(--cat-accent)] md:text-4xl">{eyebrow}</h2>}
			<h3 class="mt-3 text-xl font-semibold text-ink md:text-2xl">{title}</h3>
			<p class="mt-5 leading-relaxed text-ink-secondary">{body}</p>
		</header>
		<div class:list={['mt-10 grid gap-4 md:grid-cols-2', gridLayout]}>
			{
				items.map((item) => (
					<article class:list={[
						'relative rounded-xl border border-line bg-surface transition duration-200',
						compactCards ? 'h-full p-4 md:p-5 hover:-translate-y-1 hover:scale-[1.02] hover:border-[var(--cat-accent)] hover:ring-1 hover:ring-[var(--cat-accent)] hover:shadow-lg' : 'p-7 md:p-8',
					]}>
						<div class="h-0.5 w-10 bg-[var(--cat-accent)]"></div>
						{item.icon && <Icon name={item.icon} class:list={[compactCards ? 'mt-5 h-6 w-6' : 'mt-8 h-7 w-7', 'text-[var(--cat-accent)]']} />}
						<h3 class:list={[compactCards ? 'mt-4 text-lg' : 'mt-5 text-xl', 'font-semibold text-ink']}>{item.title}</h3>
                        <p class="mt-3 max-w-md text-base leading-relaxed text-ink-secondary">{item.text}</p>
					</article>
				))
			}
		</div>
	</Container>
</section>
