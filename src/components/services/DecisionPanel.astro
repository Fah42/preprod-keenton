---
import Container from '../ui/Container.astro';

const { eyebrow, title, body, items = [], cta } = Astro.props;
---

<section class="bg-surface-alt py-16 md:py-24">
  <Container>
    <div class="rounded-2xl border border-line bg-surface p-8 md:p-12">
      <div class="grid gap-10 lg:grid-cols-[1fr_0.9fr] lg:gap-16">
        <div>
          {eyebrow && <h2 class="font-mono text-3xl font-semibold tracking-[-0.04em] text-[var(--cat-accent)] md:text-4xl">{eyebrow}</h2>}
          <h3 class="mt-3 text-xl font-semibold text-ink md:text-2xl">{title}</h3>
          <p class="mt-5 max-w-xl leading-relaxed text-ink-secondary">{body}</p>
			{cta && <div class="mt-8"><a href={cta.href} class="inline-flex items-center gap-2 rounded-lg bg-[var(--cat-accent)] px-6 py-3 text-sm font-medium text-white transition-opacity hover:opacity-90">{cta.label} <span aria-hidden="true">→</span></a></div>}
        </div>
        <ul class="grid content-start gap-3">
          {items.map((item) => (
            <li class="rounded-lg border border-line bg-surface-alt p-5"><h3 class="font-semibold text-ink">{item.title}</h3><p class="mt-2 text-base leading-relaxed text-ink-secondary">{item.text}</p></li>
          ))}
        </ul>
      </div>
    </div>
  </Container>
</section>
