---
import Container from '../ui/Container.astro';

const { eyebrow, title, body, items = [] } = Astro.props;
---

<section class="bg-surface py-16 md:py-24">
  <Container>
    <div class="grid gap-12 lg:grid-cols-[0.75fr_1.25fr] lg:gap-20">
      <header>
        {eyebrow && <h2 class="font-mono text-3xl font-semibold tracking-[-0.04em] text-[var(--cat-accent)] md:text-4xl">{eyebrow}</h2>}
        <h3 class="mt-3 text-xl font-semibold text-ink md:text-2xl">{title}</h3>
        <p class="mt-5 leading-relaxed text-ink-secondary">{body}</p>
      </header>
      <ol class="divide-y divide-line border-y border-line">
        {items.map((item, index) => (
          <li class="grid gap-3 py-6 md:grid-cols-[3rem_1fr]">
            <span class="font-mono text-sm text-[var(--cat-accent)]">{String(index + 1).padStart(2, '0')}</span>
            <div><h3 class="font-semibold text-ink">{item.title}</h3><p class="mt-2 text-base leading-relaxed text-ink-secondary">{item.text}</p></div>
          </li>
        ))}
      </ol>
    </div>
  </Container>
</section>
