---
import Container from '../ui/Container.astro';
import Icon from '../ui/Icon.astro';

const { eyebrow, title, body, items = [], cta } = Astro.props;
---

<section class="relative overflow-hidden bg-ink py-16 text-white md:py-24">
	<div class="pointer-events-none absolute -top-24 -right-24 h-72 w-72 rounded-full bg-[var(--cat-accent)] opacity-15 blur-3xl" aria-hidden="true"></div>
	<Container class="relative">
		<div class="grid gap-12 lg:grid-cols-[0.8fr_1.2fr] lg:gap-20">
			<header class="max-w-xl">
				{eyebrow && <h2 class="font-mono text-3xl font-semibold leading-tight tracking-[-0.04em] text-[var(--cat-accent)] md:text-4xl">{eyebrow}</h2>}
				<h3 class="mt-3 text-xl font-semibold text-white md:text-2xl">{title}</h3>
				<p class="mt-5 leading-relaxed text-white/70">{body}</p>
				{
					cta && (
						<a href={cta.href} class="mt-8 inline-flex items-center gap-2 rounded-lg bg-[var(--cat-accent)] px-6 py-3 text-sm font-medium text-white transition-opacity hover:opacity-90">
							{cta.label}<span aria-hidden="true">→</span>
						</a>
					)
				}
			</header>
			<div class="grid gap-4 sm:grid-cols-2">
				{
					items.map((item, index) => (
						<article class:list={[
							'border border-white/12 bg-white/5 p-6 backdrop-blur-sm',
							index === 0 && items.length % 2 === 1 ? 'sm:col-span-2' : '',
						]}>
							{item.icon && <Icon name={item.icon} class="h-6 w-6 text-[var(--cat-accent)]" />}
							<h3 class="mt-5 text-lg font-semibold">{item.title}</h3>
                            <p class="mt-2 text-base leading-relaxed text-white/75">{item.text}</p>
						</article>
					))
				}
			</div>
		</div>
	</Container>
</section>
