---
const { title, description, href } = Astro.props;
---

<a
	href={href}
	class="group flex h-full flex-col rounded-lg border border-line bg-surface p-8 transition-colors duration-200 hover:border-accent"
>
	<h3 class="text-xl font-semibold text-ink">{title}</h3>
	<p class="mt-3 grow text-base leading-relaxed text-ink-secondary">{description}</p>
	<p class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-accent-dark">
		En savoir plus
		<span class="transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true">&rarr;</span>
	</p>
</a>
