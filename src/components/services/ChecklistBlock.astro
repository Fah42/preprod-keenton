---
import Container from '../ui/Container.astro';
import Icon from '../ui/Icon.astro';

const { eyebrow, title, body, items = [], cta } = Astro.props;
---

<section class="bg-surface py-16 md:py-24">
	<Container>
		<div class="grid gap-12 lg:grid-cols-[0.78fr_1.22fr] lg:gap-20">
			<header class="max-w-xl">
                {eyebrow && <h2 class="font-mono text-3xl font-semibold tracking-[-0.04em] text-[var(--cat-accent)] md:text-4xl">{eyebrow}</h2>}
                <h3 class="mt-3 text-xl font-semibold text-ink md:text-2xl">{title}</h3>
				<p class="mt-5 leading-relaxed text-ink-secondary">{body}</p>
				{
					cta && (
						<a href={cta.href} class="mt-8 inline-flex items-center gap-2 rounded-lg bg-[var(--cat-accent)] px-6 py-3 text-sm font-medium text-white transition-opacity hover:opacity-90">
							{cta.label}<span aria-hidden="true">→</span>
						</a>
					)
				}
			</header>
			<ul class="border-t border-line">
				{
					items.map((item) => (
						<li class="grid gap-4 border-b border-line py-6 sm:grid-cols-[1fr_auto] sm:items-start">
							<div>
								<h3 class="font-semibold text-ink">{item.title}</h3>
                                <p class="mt-2 text-base leading-relaxed text-ink-secondary">{item.text}</p>
							</div>
							{item.icon && <Icon name={item.icon} class="hidden h-6 w-6 text-[var(--cat-accent)] sm:block" />}
						</li>
					))
				}
			</ul>
		</div>
	</Container>
</section>
