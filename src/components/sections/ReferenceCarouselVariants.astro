---
// Carrousel de références retenu.
import Container from '../ui/Container.astro';

const { items = [] } = Astro.props;
const duplicatedItems = [...items, ...items];
---

<!-- Section blanche continue : le mouvement vient uniquement des logos. -->
<section class="overflow-hidden border-b border-line bg-surface pt-12 pb-8 md:pt-14 md:pb-10">
  <Container>
	<header class="mb-10 max-w-4xl md:mb-12" data-reveal>
		<h2 class="display-title text-[clamp(2.1rem,4vw,3rem)] text-ink">Ils nous font confiance</h2>
    </header>
  </Container>
  <div class="reference-marquee relative py-7">
    <div class="reference-marquee__track">
      {duplicatedItems.map((item) => (
        <figure class="home-reference-item flex h-20 w-48 shrink-0 items-center justify-center px-6">
          <img src={item.src} alt={item.name} class="home-reference-logo max-h-16 max-w-full object-contain" loading="lazy" />
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .reference-marquee {
    /* Fondu discret sur les bords du rail. */
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }

  .reference-marquee__track {
    display: flex;
    width: max-content;
    animation: references-scroll 42s linear infinite;
  }

  /* Defilement continu ; le survol met en pause pour laisser lire. */
  .reference-marquee:hover .reference-marquee__track {
    animation-play-state: paused;
  }

  @keyframes references-scroll {
    to { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .reference-marquee__track { animation: none; }
  }
</style>
