---
import Container from '../ui/Container.astro';
import Icon from '../ui/Icon.astro';

const { items = [] } = Astro.props;
---


<section id="expertises" class="border-b border-line bg-surface-alt">
	<Container class="py-12 md:py-16">
		<header class="max-w-none">
			<p class="font-heading text-base leading-none font-semibold tracking-[0.02em] text-accent-dark">Nos expertises</p>
			<h2 class="mt-5 text-[clamp(2rem,2.5vw,2.5rem)] leading-tight font-semibold text-ink">Lorem ipsum dolor sit amet, consectetur adipiscing elit</h2>
			<p class="mt-6 max-w-5xl text-base leading-relaxed text-ink-secondary md:text-lg">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare, eros dolor interdum nulla, ut commodo diam libero vitae erat.</p>
		</header>

		<div class="mt-9 grid gap-4 md:grid-cols-2 xl:grid-cols-[repeat(16,minmax(0,1fr))]">
			{
				items.map((item, index) => (
					<a
						href={item.href}
						class:list={[
							'expertise-card group relative min-h-[30rem] overflow-hidden rounded-xl border border-line p-6 transition duration-200 hover:-translate-y-1',
							index < 4 ? 'xl:col-span-4' : 'xl:col-span-4',
							index === 4 && 'xl:col-start-3',
						]}
						style={`--expertise-accent: ${item.accentColor}`}
					>
						<div class="expertise-card__rail absolute inset-y-0 left-0 w-[3px]"></div>
						<img
							src={`/images/expertises/${item.slug}.png`}
							alt=""
							class="expertise-card__emblem pointer-events-none absolute right-2 bottom-4 h-24 w-24 origin-bottom-right object-contain transition duration-300 md:h-28 md:w-28 group-hover:scale-[1.03]"
						/>
						<div class="relative">
							<Icon name={item.icon} class="h-5 w-5 text-[var(--expertise-accent)]" />
						</div>
						<div class="relative mt-6">
							<h3 class="whitespace-nowrap text-[clamp(1rem,1.25vw,1.35rem)] leading-tight font-semibold text-ink">{item.title}</h3>
							<ul class="mt-4 space-y-2 text-base leading-relaxed tracking-[-0.015em] text-ink-secondary">
								{item.points.map((point) => <li class="flex gap-2"><span class="text-[var(--expertise-accent)]">•</span><span>{point}</span></li>)}
							</ul>
						</div>
					</a>
				))
			}
		</div>
	</Container>
</section>

<style>
	.expertise-card {
		background: var(--color-surface);
		border-color: var(--color-line);
	}

	.expertise-card__rail {
		background: var(--color-line);
		transition: background-color 200ms ease;
	}

	.expertise-card__emblem {
		filter: grayscale(1);
		mix-blend-mode: multiply;
		opacity: 0.22;
	}

	.expertise-card:hover {
		border-color: var(--expertise-accent);
		background: color-mix(in srgb, var(--expertise-accent) 5%, var(--color-surface));
		box-shadow: 0 18px 34px color-mix(in srgb, var(--expertise-accent) 16%, transparent);
	}

	.expertise-card:hover .expertise-card__rail {
		background: var(--expertise-accent);
	}

	.expertise-card:hover .expertise-card__emblem {
		filter:
			drop-shadow(0 0 10px color-mix(in srgb, var(--expertise-accent) 62%, transparent))
			drop-shadow(0 0 28px color-mix(in srgb, var(--expertise-accent) 38%, transparent));
		mix-blend-mode: normal;
		opacity: 1;
	}

</style>
