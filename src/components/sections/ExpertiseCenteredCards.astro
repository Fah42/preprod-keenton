---
// Grille des 7 expertises. L'en-tete (H2 SEO + intro) vient de home.js
// (`expertisesSection`) : le composant ne porte aucun texte en dur.
import Container from '../ui/Container.astro';
import Icon from '../ui/Icon.astro';

const { items = [], eyebrow, title, intro } = Astro.props;
---


<section id="expertises" class="border-b border-line bg-surface">
	<Container class="pt-12 pb-16 md:pt-14 md:pb-24">
		<header class="max-w-none" data-reveal>
			<h2 class="display-title text-[clamp(2.1rem,4vw,3rem)] text-ink">{eyebrow}</h2>
			<p class="mt-6 max-w-4xl text-xl leading-snug font-semibold text-ink md:text-2xl">{title}</p>
			<p class="mt-4 max-w-4xl text-base leading-relaxed text-ink-secondary md:text-lg">{intro}</p>
		</header>

		<div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-[repeat(16,minmax(0,1fr))]">
			{
				items.map((item, index) => (
					<a
						href={item.href}
						class:list={[
							'expertise-card group relative min-h-[30rem] overflow-hidden rounded-xl border border-line p-6 transition duration-200 hover:-translate-y-1',
							index < 4 ? 'xl:col-span-4' : 'xl:col-span-4',
							index === 4 && 'xl:col-start-3',
						]}
						style={`--expertise-accent: ${item.accentColor}`}
					>
						<div class="expertise-card__rail absolute inset-y-0 left-0 w-[3px]"></div>
						<img
							src={`/images/expertises/${item.slug}.png`}
							alt=""
							loading="lazy"
							class="expertise-card__emblem pointer-events-none absolute right-4 bottom-4 h-[4.2rem] w-[4.2rem] origin-bottom-right object-contain transition duration-300 group-hover:scale-[1.04]"
						/>
						<div class="relative flex items-center">
							<span class="flex h-9 w-9 items-center justify-center rounded-md bg-[color-mix(in_srgb,var(--expertise-accent)_12%,white)]">
								<Icon name={item.icon} class="h-5 w-5 text-[var(--expertise-accent)]" />
							</span>
						</div>
						<div class="relative mt-6">
							<h3 class="expertise-card__title whitespace-nowrap text-[clamp(1rem,1.25vw,1.35rem)] leading-tight font-bold">{item.title}</h3>
							<ul class="mt-4 space-y-2 text-base leading-relaxed tracking-[-0.015em] text-ink-secondary">
								{item.points.map((point) => <li class="flex gap-2"><span class="expertise-card__bullet">•</span><span>{point}</span></li>)}
							</ul>
						</div>
					</a>
				))
			}
		</div>
	</Container>
</section>

<style>
	.expertise-card {
		background: var(--color-surface);
		border-color: var(--color-line);
		box-shadow: var(--shadow-cold);
	}

	/* La carte reste monochrome ; seule l'icone fonctionnelle porte la couleur. */
	.expertise-card__rail {
		background: var(--color-line);
		transition: background 200ms ease;
	}

	.expertise-card__title {
		color: var(--color-ink);
		transition: color 200ms ease;
	}

	.expertise-card__bullet {
		color: color-mix(in srgb, var(--color-ink-secondary) 45%, transparent);
		transition: color 200ms ease;
	}

	.expertise-card__emblem {
		filter: grayscale(1);
		mix-blend-mode: multiply;
		opacity: 0.32;
	}

	.expertise-card:hover {
		border-color: var(--expertise-accent);
		background: color-mix(in srgb, var(--expertise-accent) 5%, var(--color-surface));
		box-shadow: var(--shadow-cold);
	}

	.expertise-card:hover .expertise-card__rail {
		background: var(--expertise-accent);
	}

	.expertise-card:hover .expertise-card__title,
	.expertise-card:hover .expertise-card__bullet {
		color: var(--expertise-accent);
	}

	.expertise-card:hover .expertise-card__emblem {
		filter:
			drop-shadow(0 0 2px color-mix(in srgb, var(--expertise-accent) 50%, transparent))
			drop-shadow(0 0 8px color-mix(in srgb, var(--expertise-accent) 31%, transparent));
		mix-blend-mode: normal;
		opacity: 1;
	}

</style>
