---
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';

const { title, text, cta } = Astro.props;
---

<section class="relative overflow-hidden bg-dark bg-grid-dark text-dark-text">
	<div class="glow-accent pointer-events-none absolute inset-0" aria-hidden="true"></div>
	<Container class="relative py-20 text-center md:py-28">
		<h2 class="mx-auto max-w-5xl text-3xl leading-tight font-semibold text-white md:text-[2.5rem]">
			{title}
		</h2>
		<p class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-dark-text-secondary md:text-lg">{text}</p>
		<div class="mt-10">
			<Button href={cta.href} variant="primary">{cta.label}</Button>
		</div>
	</Container>
</section>
