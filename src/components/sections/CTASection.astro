---
// CTA final : navy abysse, double halo central bleu -> cyan, grille technique
// revelee par la lumiere. Echo exact de la section Philosophie ; le footer
// (footer-from identique au fond) enchaine sans rupture.
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';

const { title, text, cta, backgroundColor, titleColor, textColor, buttonVariant = 'primary' } = Astro.props;
---

<section
	class="relative overflow-hidden bg-dark text-dark-text"
	style={backgroundColor ? `background-color: ${backgroundColor}` : undefined}
>
	{!backgroundColor && <div class="glow-accent pointer-events-none absolute inset-0" aria-hidden="true"></div>}
	{!backgroundColor && <div class="bg-grid-dark pointer-events-none absolute inset-0 [mask-image:radial-gradient(46rem_28rem_at_50%_45%,black,transparent_78%)]" aria-hidden="true"></div>}
	<Container class="relative py-20 text-center md:py-28">
		<h2
			class="display-title mx-auto max-w-5xl text-[clamp(2.05rem,4vw,3.2rem)] text-white"
			style={titleColor ? `color: ${titleColor}` : undefined}
		>
			{title}
		</h2>
		<p
			class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-dark-text-secondary md:text-lg"
			style={textColor ? `color: ${textColor}` : undefined}
		>{text}</p>
		<div class="mt-10">
			<Button href={cta.href} variant={buttonVariant} arrow>{cta.label}</Button>
		</div>
	</Container>
</section>
