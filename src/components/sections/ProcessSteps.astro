---
const { steps = [] } = Astro.props;
---

<ol class="relative grid gap-8 md:grid-cols-5 md:gap-5">
  <div class="absolute top-4 right-[10%] left-[10%] hidden h-px bg-line md:block" aria-hidden="true"></div>
  {steps.map((step, index) => (
    <li class="relative flex gap-4 md:block">
      <span class="relative z-10 flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-accent bg-surface font-mono text-xs text-accent-dark md:mx-auto">
        {String(index + 1).padStart(2, '0')}
      </span>
      <div class="md:mt-6 md:text-center">
        <h3 class="text-lg leading-snug font-semibold text-ink md:text-xl">{step.title}</h3>
        <p class="mt-3 text-base leading-relaxed text-ink-secondary">{step.text}</p>
      </div>
    </li>
  ))}
</ol>
