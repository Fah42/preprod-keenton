---
// Bloc reutilisable "Visuel Gauche + Texte Droite" / "Visuel Droite +
// Texte Gauche". `reverse` pilote l'inversion et `showIllustration` permet
// de conserver exactement le meme contenu avec ou sans visuel.
import Container from '../ui/Container.astro';
import Icon from '../ui/Icon.astro';
import PlaceholderVisual from '../ui/PlaceholderVisual.astro';
import TechnologyLogos from '../services/TechnologyLogos.astro';

const {
	eyebrow,
	title,
	body,
	icon,
	image,
	reverse = false,
	showIllustration = true,
	variant = 'simple',
	points = [],
	stats = [],
	columns = [],
	technologyTitle,
	technologies = [],
} = Astro.props;
---

<section class:list={['py-14 md:py-20', reverse ? 'bg-surface-alt' : 'bg-surface']}>
	<Container>
		<div
			class:list={[
				'grid gap-10 lg:items-center lg:gap-16',
				showIllustration && (reverse ? 'lg:grid-cols-[minmax(0,7fr)_minmax(0,3fr)]' : 'lg:grid-cols-[minmax(0,3fr)_minmax(0,7fr)]'),
			]}
		>
			{showIllustration && (
				<div class:list={[reverse && 'lg:order-2']}>
					{image ? (
						<img
							src={image.src}
							alt={image.alt}
							width="1200"
							height="900"
							loading="lazy"
							decoding="async"
							class="aspect-4/3 w-full rounded-2xl border-2 bg-[color-mix(in_srgb,var(--cat-accent)_6%,white)] object-contain"
							style="border-color: var(--feature-image-border-color, color-mix(in srgb, var(--cat-accent) 35%, white)); padding: var(--feature-image-padding, 0);"
						/>
					) : (
						<PlaceholderVisual icon={icon} />
					)}
				</div>
			)}
			<div class:list={[reverse && showIllustration && 'lg:order-1']}>
				{eyebrow && <h2 class="font-mono text-3xl font-semibold tracking-[-0.04em] text-[var(--cat-accent)] md:text-4xl">{eyebrow}</h2>}
				<div class="mt-3 flex items-center gap-3">
					{icon && <Icon name={icon} class="h-6 w-6 shrink-0 text-[var(--cat-accent)]" />}
					<h3 class="text-xl font-semibold text-ink md:text-2xl">{title}</h3>
				</div>
				{technologies.length > 0 ? (
					<div class="mt-4 leading-relaxed text-ink-secondary">
						<span>{body}</span>
						<TechnologyLogos title={technologyTitle} items={technologies} />
					</div>
				) : (
					<p class="mt-4 leading-relaxed text-ink-secondary">{body}</p>
				)}
				{
					variant === 'list' && (
						<ul class="mt-6 grid gap-x-8 gap-y-3 border-t border-line pt-5 sm:grid-flow-col sm:grid-rows-3">
							{points.map((point) => <li class="flex gap-3 text-base leading-relaxed text-ink-secondary"><span class="font-semibold text-[var(--cat-accent)]">✓</span>{point}</li>)}
						</ul>
					)
				}
				{
					variant === 'tiles' && (
						<div class="mt-6 grid gap-3 sm:grid-cols-2">
							{points.map((point) => <p class="rounded-lg border border-line bg-surface-alt px-4 py-3 text-base leading-relaxed text-ink-secondary">{point}</p>)}
						</div>
					)
				}
				{
					variant === 'callout' && points[0] && (
						<aside class="mt-6 border-l-2 border-[var(--cat-accent)] bg-surface-alt px-5 py-4 text-base leading-relaxed text-ink-secondary">{points[0]}</aside>
					)
				}
				{
					variant === 'metrics' && (
						<div class="mt-6 grid grid-cols-3 divide-x divide-line border border-line">
							{stats.map((stat) => <div class="p-4"><strong class="block text-sm text-ink">{stat.value}</strong><span class="mt-1 block text-xs leading-snug text-ink-secondary">{stat.label}</span></div>)}
						</div>
					)
				}
				{
					variant === 'steps' && (
						<ol class="mt-6 divide-y divide-line border-y border-line">
							{points.map((point, index) => <li class="grid grid-cols-[2rem_1fr] gap-3 py-3 text-base leading-relaxed text-ink-secondary"><span class="font-mono text-[var(--cat-accent)]">{String(index + 1).padStart(2, '0')}</span>{point}</li>)}
						</ol>
					)
				}
				{
					variant === 'comparison' && (
						<div class="mt-6 grid gap-3 sm:grid-cols-2">
							{columns.map((column) => (
								<div class="border border-line bg-surface-alt p-4">
									<p class="font-semibold text-ink">{column.title}</p>
									<ul class="mt-3 space-y-2 text-base leading-relaxed text-ink-secondary">{column.items.map((item) => <li>{item}</li>)}</ul>
								</div>
							))}
						</div>
					)
				}
				{
					variant === 'quote' && points[0] && (
						<blockquote class="mt-6 rounded-xl bg-[color-mix(in_srgb,var(--cat-accent)_9%,white)] p-6 text-lg leading-relaxed font-medium text-ink">« {points[0]} »</blockquote>
					)
				}
			</div>
		</div>
	</Container>
</section>
