---
// Section de cartes (cf. maquette tete1.png) : titre centre a accent bleu,
// intro optionnelle, cartes blanches bordees avec icone + titre, liste a
// puces "›" et lien optionnel. Reutilisee sur l'accueil (piliers) et les
// pages produit (offres) pour garder une structure commune.
import Container from '../ui/Container.astro';
import Icon from '../ui/Icon.astro';

const { id, titlePrefix, titleAccent, intro, theme = 'light', items = [] } = Astro.props;

const themes = {
	light: 'bg-surface',
	alt: 'bg-surface-alt',
};

// 6 cartes ou plus (les 7 expertises) : 4 colonnes -> repartition 4+3, plus
// equilibree qu'un 5+2. 5 cartes exactement : 5 colonnes. En dessous : 4.
const gridCols = items.length >= 6 ? 'xl:grid-cols-4' : items.length >= 5 ? 'xl:grid-cols-5' : 'xl:grid-cols-4';
---

<section id={id} class:list={[themes[theme], 'py-16 md:py-20']}>
	<Container>
		<h2 class="text-center text-xl font-bold uppercase tracking-[0.06em] text-ink md:text-2xl">
			{titlePrefix} <span class="text-accent">{titleAccent}</span>
		</h2>
		{
			intro && (
				<p class="mx-auto mt-4 max-w-2xl text-center leading-relaxed text-ink-secondary">
					{intro}
				</p>
			)
		}

		<div class:list={['mt-10 grid gap-6 sm:grid-cols-2 md:mt-12 lg:grid-cols-3', gridCols]}>
			{
				items.map((item) => (
					<article class="flex flex-col rounded-xl border border-line bg-surface p-6 shadow-[0_1px_3px_rgb(10_16_27/0.04)]">
						<div class="flex items-center gap-4">
							{item.icon && <Icon name={item.icon} class="h-10 w-10 shrink-0 text-accent" />}
							<h3 class="text-[15px] leading-snug font-bold uppercase tracking-[0.02em] text-ink">
								{item.title}
							</h3>
						</div>
						<ul class="mt-5 space-y-2.5">
							{item.points.map((point) => (
								<li class="flex gap-2.5 text-base leading-relaxed text-ink-secondary">
									<span class="font-semibold text-accent" aria-hidden="true">
										›
									</span>
									{point}
								</li>
							))}
						</ul>
						{item.href && (
							<a
								href={item.href}
								class="mt-auto inline-flex items-center gap-2 pt-6 text-sm font-semibold text-accent transition-colors hover:text-accent-dark"
							>
								En savoir plus
								<svg class="h-3.5 w-3.5" viewBox="0 0 16 16" fill="none" aria-hidden="true">
									<path
										d="M2 8h11M9.5 4l4 4-4 4"
										stroke="currentColor"
										stroke-width="1.6"
										stroke-linecap="round"
										stroke-linejoin="round"
									/>
								</svg>
							</a>
						)}
					</article>
				))
			}
		</div>
	</Container>
</section>
