---
import Container from '../ui/Container.astro';

const { items = [] } = Astro.props;
---

<section class="bg-surface-alt py-20 md:py-28">
  <Container>
    <div class="grid gap-12 lg:grid-cols-[0.7fr_1.3fr] lg:gap-20">
      <header>
        <p class="font-heading text-base leading-none font-semibold tracking-[0.02em] text-accent-dark">Questions fréquentes</p>
        <h2 class="mt-5 text-3xl leading-tight font-semibold text-ink md:text-[2.5rem]">Avant de commencer</h2>
        <p class="mt-6 text-base leading-relaxed text-ink-secondary md:text-lg">Les premières réponses aux questions qui reviennent avant une étude sur site ou une reprise de périmètre.</p>
      </header>
      <div class="divide-y divide-line border-y border-line">
        {items.map((item) => (
          <details class="group py-5">
            <summary class="font-heading flex cursor-pointer list-none items-center justify-between gap-5 text-lg leading-snug font-semibold text-ink">
              {item.question}<span class="text-xl font-normal text-accent transition-transform group-open:rotate-45">+</span>
            </summary>
            <p class="max-w-2xl pt-4 text-base leading-relaxed text-ink-secondary">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </Container>
</section>
