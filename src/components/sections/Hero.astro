---
// Hero de la page d'accueil : même réservation d'illustration 4:3 que les expertises.
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';

const { eyebrow, title, titleAccent, subtitle, image, primaryCta, secondaryCta } = Astro.props;
---

<section class="border-b border-line bg-surface">
	<Container class="grid items-center gap-6 py-0 lg:grid-cols-2 lg:gap-10">
		<div class="max-w-2xl py-6 md:py-8 lg:py-3">
			<p class="reveal reveal-1 font-heading text-base leading-none font-semibold tracking-[0.02em] text-accent">
				{eyebrow}
			</p>
			<h1 class="reveal reveal-2 mt-5 text-4xl leading-[1.12] font-semibold text-ink md:text-[2.6rem] lg:text-[2.8rem]">
				{title}
				<span class="text-accent"> {titleAccent}</span>
			</h1>
			<p class="reveal reveal-3 mt-6 text-base leading-relaxed text-ink-secondary md:text-lg">
				{subtitle}
			</p>
			<div class="reveal reveal-4 mt-7 flex flex-wrap gap-4">
				<Button href={primaryCta.href} variant="primary" arrow>{primaryCta.label}</Button>
				<Button href={secondaryCta.href} variant="dark" arrow>{secondaryCta.label}</Button>
			</div>
		</div>
		<div class="my-3 aspect-[4/3] w-full max-w-[36rem] justify-self-center lg:w-[36rem] lg:justify-self-end">
			{
				image ? (
					<img src={image.src} alt={image.alt} class="h-full w-full object-contain" />
				) : (
					<div class="flex h-full w-full items-center justify-center rounded-xl border border-dashed border-line bg-surface-alt">
						<span class="text-xs font-medium uppercase tracking-[0.14em] text-ink-secondary/70">Illustration à venir</span>
					</div>
				)
			}
		</div>
	</Container>
</section>
