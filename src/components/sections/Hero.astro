---
// Hero de la page d'accueil, direction "Profondeur Aurora" : fond blanc,
// grille technique revelee autour de l'illustration, double halo bleu/cyan,
// H1 Poppins 700 avec accent en degrade texte, bande de reassurance posee
// sur un filet lumineux (items `reassurance` de home.js via `highlights`).
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';

const { title, titleAccent, subtitle, image, primaryCta, secondaryCta, highlights = [] } = Astro.props;
const currentYear = new Date().getFullYear();
---

<section class="relative overflow-hidden border-b border-line bg-surface">
	{/* Filet lumineux anime : bleu Keenton vers blanc, puis retour au bleu. */}
	<div class="spectrum-beam pointer-events-none absolute inset-x-0 top-0 z-20 h-[3px]" aria-hidden="true"></div>
	{/* Grille technique, revelee par la lumiere autour de l'illustration */}
	<div
		class="bg-grid-light pointer-events-none absolute inset-0 [mask-image:radial-gradient(52rem_38rem_at_72%_38%,black,transparent_80%)]"
		aria-hidden="true"
	></div>

	<Container class="relative grid items-center gap-6 py-0 lg:grid-cols-2 lg:gap-10">
		<div class="max-w-2xl py-10 md:py-12 lg:py-8">
			<h1 class="display-title reveal reveal-1 text-[clamp(2.3rem,4.2vw,3.25rem)] text-ink">
				{title}
				<span class="bg-linear-to-r from-accent-dark via-accent to-[#45bdf0] bg-clip-text text-transparent"> {titleAccent}</span>
			</h1>
			<p class="reveal reveal-2 mt-6 text-base leading-relaxed text-ink-secondary md:text-lg">
				{subtitle}
			</p>
			<div class="reveal reveal-3 mt-8 flex flex-wrap gap-4">
				<Button href={primaryCta.href} variant="primary" arrow>{primaryCta.label}</Button>
				<Button href={secondaryCta.href} variant="dark" arrow>{secondaryCta.label}</Button>
			</div>
		</div>
		<div class="relative my-3 aspect-[4/3] w-full max-w-[36rem] justify-self-center lg:w-[36rem] lg:justify-self-end">
			{/* Double halo : bleu Keenton + pointe cyan, derriere l'illustration */}
			<div
				class="pointer-events-none absolute -inset-10"
				style="background: radial-gradient(30rem 22rem at 50% 45%, rgb(41 170 227 / 0.07), transparent 70%), radial-gradient(18rem 14rem at 68% 28%, rgb(111 224 255 / 0.05), transparent 70%)"
				aria-hidden="true"
			></div>
			{
				image ? (
					<img
						src={image.src}
						alt={image.alt}
						width="1600"
						height="1200"
						loading="eager"
						fetchpriority="high"
						class="relative h-full w-full object-contain"
					/>
				) : (
					<div class="flex h-full w-full items-center justify-center rounded-xl border border-dashed border-line bg-surface-alt">
						<span class="text-xs font-medium uppercase tracking-[0.14em] text-ink-secondary/70">Illustration à venir</span>
					</div>
				)
			}
		</div>
	</Container>

	{
		highlights.length > 0 && (
			<div class="relative">
				<div class="absolute inset-x-0 top-0 h-px bg-line" aria-hidden="true" />
				<Container>
					<ul class="grid auto-rows-fr grid-cols-2 items-stretch divide-line md:grid-cols-4 md:divide-x">
						{highlights.map((item) => {
							const uptimeYears = item.foundedYear ? Math.max(0, currentYear - item.foundedYear) : undefined;
							const displayLines = item.displayLines ?? [item.title];

							return (
							<li class="flex min-h-[7.5rem] flex-col items-center justify-center gap-2 px-3 py-4 text-center sm:px-4 lg:min-h-[7rem] lg:flex-row lg:justify-start lg:gap-3 lg:px-6 lg:text-left">
								<span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-accent/10 text-accent-dark">
									<Icon name={item.icon} class="h-4 w-4" />
								</span>
								<div class="min-w-0">
									<p class="font-heading text-base font-semibold leading-snug text-ink">
										{
											item.metrics ? (
												<>
													<span aria-hidden="true">
														SLA{' '}
														<span
															class="tabular-nums"
															data-animated-counter
															data-counter-decimals="2"
															data-counter-kind="percent"
															data-counter-target={item.metrics.sla}
														>
															99,99%
														</span>
														, Passion{' '}
														<span
															class="tabular-nums"
															data-animated-counter
															data-counter-decimals="0"
															data-counter-kind="percent"
															data-counter-target={item.metrics.passion}
														>
															300%
														</span>
													</span>
													<span class="sr-only">{item.title}</span>
												</>
											) : uptimeYears !== undefined ? (
												<>
													<span aria-hidden="true">
														<span class="block lg:whitespace-nowrap">
															<span
																class="tabular-nums"
																data-animated-counter
																data-counter-decimals="0"
																data-counter-kind="years"
																data-counter-target={uptimeYears}
																data-uptime-counter
															>
																{uptimeYears} ans
															</span>{' '}
															{displayLines[0]}
														</span>
														{displayLines.slice(1).map((line) => <span class="block lg:whitespace-nowrap">{line}</span>)}
													</span>
													<span class="sr-only">{uptimeYears} ans {item.title}</span>
												</>
											) : item.displayLines ? (
												<>
													<span aria-hidden="true">
														{displayLines.map((line) => <span class="block lg:whitespace-nowrap">{line}</span>)}
													</span>
													<span class="sr-only">{item.title}</span>
												</>
											) : (
												item.title
											)
										}
									</p>
									{item.text && <p class="mt-1 text-sm leading-relaxed text-ink-secondary">{item.text}</p>}
								</div>
							</li>
							);
						})}
					</ul>
				</Container>
			</div>
		)
	}
</section>

<script>
	function initializeAnimatedCounters() {
		const counters = document.querySelectorAll('[data-animated-counter]');
		const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		const animate = (counter) => {
			if (!(counter instanceof HTMLElement) || counter.dataset.animated === 'true') return;

			const target = Number(counter.dataset.counterTarget ?? 0);
			const decimals = Number(counter.dataset.counterDecimals ?? 0);
			const kind = counter.dataset.counterKind;
			const formatNumber = (value) =>
				value.toLocaleString('fr-FR', {
					minimumFractionDigits: decimals,
					maximumFractionDigits: decimals,
				});
			const formatYears = (years) => `${years} ${years === 1 ? 'an' : 'ans'}`;
			const formatValue = (value) => kind === 'years' ? formatYears(value) : `${formatNumber(value)}%`;
			counter.dataset.animated = 'true';

			if (reduceMotion || target <= 0) {
				counter.textContent = formatValue(target);
				return;
			}

			counter.textContent = formatValue(0);
			const duration = 2500;
			let startedAt;

			const tick = (timestamp) => {
				startedAt ??= timestamp;
				const progress = Math.min((timestamp - startedAt) / duration, 1);
				const factor = 10 ** decimals;
				const currentValue = Math.min(target, Math.floor(target * progress * factor) / factor);
				counter.textContent = formatValue(progress < 1 ? currentValue : target);

				if (progress < 1) requestAnimationFrame(tick);
			};

			requestAnimationFrame(tick);
		};

		if (reduceMotion || !('IntersectionObserver' in window)) {
			counters.forEach(animate);
			return;
		}

		const observer = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					if (!entry.isIntersecting) continue;
					animate(entry.target);
					observer.unobserve(entry.target);
				}
			},
			{ threshold: 0.45 },
		);

		counters.forEach((counter) => observer.observe(counter));
	}

	document.addEventListener('astro:page-load', initializeAnimatedCounters);
	initializeAnimatedCounters();
</script>
