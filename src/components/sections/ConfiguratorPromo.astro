---
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';

const { eyebrow, title, text, cta } = Astro.props;
---

<section class="bg-surface py-20 md:py-28">
  <Container>
    <div class="grid items-center gap-10 rounded-2xl border border-[color-mix(in_srgb,var(--color-ink)_16%,var(--color-line))] bg-surface-alt p-8 shadow-[0_16px_36px_rgb(10_16_27/0.06)] md:p-12 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16">
      <div>
        <p class="font-heading text-base leading-none font-semibold tracking-[0.02em] text-accent-dark">{eyebrow}</p>
        <h2 class="mt-5 text-3xl leading-tight font-semibold text-ink md:text-[2.5rem]">{title}</h2>
        <p class="mt-6 max-w-xl text-base leading-relaxed text-ink-secondary md:text-lg">{text}</p>
        <div class="mt-8"><Button href={cta.href} variant="primary" arrow>{cta.label}</Button></div>
      </div>
      <div class="rounded-xl border border-[color-mix(in_srgb,var(--color-ink)_16%,var(--color-line))] bg-surface p-6 shadow-[0_8px_20px_rgb(10_16_27/0.04)]">
        <div class="flex items-center gap-2 border-b border-[color-mix(in_srgb,var(--color-ink)_16%,var(--color-line))] pb-4">
          {[1, 2, 3, 4].map((step) => <span class:list={['flex h-7 w-7 items-center justify-center rounded-full font-mono text-xs', step === 1 ? 'bg-accent text-white' : 'border border-ink/20 text-ink-secondary']}>{step}</span>)}
        </div>
        <div class="mt-5 space-y-3">
          <div class="h-3 w-2/3 rounded bg-ink/12"></div>
          <div class="h-16 rounded-lg border border-accent bg-accent/8"></div>
          <div class="h-16 rounded-lg border border-ink/15"></div>
          <div class="h-16 rounded-lg border border-ink/15"></div>
        </div>
      </div>
    </div>
  </Container>
</section>
