---
// Promo du configurateur : carte "mini-sombre" navy avec liseret aurora et
// halo bleu derriere le mock, posee sur une surface blanche simple. Aucun PNG ici :
// le mock est dessine en CSS (panneau console).
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';

const { eyebrow, title, text, cta } = Astro.props;
---

<section class="bg-surface pt-12 pb-10 md:pt-14 md:pb-10">
  <Container>
	<header class="mb-8 md:mb-10" data-reveal>
		<h2 class="display-title text-[clamp(2.1rem,4vw,3rem)] text-ink">{eyebrow}</h2>
	</header>
    <div
      class="aurora-border relative grid items-center gap-10 overflow-hidden rounded-2xl p-8 text-dark-text shadow-cold-lg md:p-12 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16"
      style="--aurora-bg: linear-gradient(160deg, #0b1730, #050b1c)"
    >
      <div
        class="pointer-events-none absolute inset-0"
        style="background: radial-gradient(26rem 20rem at 78% 55%, rgb(41 170 227 / 0.06), transparent 70%)"
        aria-hidden="true"
      ></div>
      <div class="relative">
		<h3 class="text-xl leading-snug font-semibold text-dark-text md:text-2xl">{title}</h3>
        <p class="mt-4 max-w-xl text-base leading-relaxed text-dark-text-secondary md:text-lg">{text}</p>
        <div class="mt-8"><Button href={cta.href} variant="primary" arrow>{cta.label}</Button></div>
      </div>
      <div class="relative rounded-xl border border-dark-line bg-dark-card p-6">
        <div class="flex items-center gap-2 border-b border-dark-line pb-4">
          {[1, 2, 3, 4].map((step) => (
            <span
              class:list={[
                'flex h-7 w-7 items-center justify-center rounded-full font-mono text-xs',
                step === 1
									? 'bg-accent text-white shadow-[0_0_14px_rgb(41_170_227/0.4)]'
                  : 'border border-white/15 text-dark-text-secondary',
              ]}
            >
              {step}
            </span>
          ))}
        </div>
        <div class="mt-5 space-y-3">
          <div class="h-3 w-2/3 rounded bg-white/8"></div>
          <div class="h-16 rounded-lg border border-accent bg-accent/10"></div>
          <div class="h-16 rounded-lg border border-white/15"></div>
          <div class="h-16 rounded-lg border border-white/15"></div>
        </div>
      </div>
    </div>
  </Container>
</section>
