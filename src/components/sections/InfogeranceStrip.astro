---
// Bandeau compact "ce périmètre existe aussi en infogérance", affiché sur
// chaque page expertise sauf /expertises/infogerance. Esthetique "ligne de
// supervision" : point de statut anime + libelle mono entre crochets + lien.
// La teinte est volontairement celle de la categorie infogerance (or, cf.
// site.js), pas le --cat-accent de la page courante : le bandeau se lit
// comme un renvoi vers l'offre infogerance, pas comme un element de la page.
import Container from '../ui/Container.astro';
import { expertises } from '../../data/site.js';

const infogerance = expertises.find((e) => e.slug === 'infogerance');
---

<aside class="bg-surface py-5 md:py-6" aria-label="Infogérance disponible pour cette expertise">
	<Container>
		<a
			href={infogerance.href}
			class="infogerance-strip group flex flex-col gap-3 rounded-xl border border-line bg-surface px-5 py-4 transition duration-200 md:flex-row md:items-center md:gap-6 md:px-6"
			style={`--strip-accent: ${infogerance.accentColor}`}
		>
			<span class="flex shrink-0 items-center gap-3">
				<span class="status-dot h-2.5 w-2.5 rounded-full bg-[var(--strip-accent)]" aria-hidden="true"></span>
				<span class="infogerance-strip__label font-mono text-xs font-medium uppercase tracking-[0.18em]">[ infogérance ]</span>
			</span>
			<span class="flex-1 text-sm leading-relaxed text-ink-secondary md:text-base">
				Vous pouvez confier ce périmètre à nos équipes, qui en assurent la gestion au quotidien.
			</span>
			<span class="infogerance-strip__cta inline-flex shrink-0 items-center gap-2 text-sm font-medium text-ink transition-colors">
				Découvrir l'infogérance
				<svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="none" aria-hidden="true">
					<path d="M5.5 3.5 10 8l-4.5 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
				</svg>
			</span>
		</a>
	</Container>
</aside>

<style>
	.infogerance-strip__label,
	.infogerance-strip:hover .infogerance-strip__cta {
		/* Or assombri pour rester lisible en petit corps sur fond blanc. */
		color: color-mix(in srgb, var(--strip-accent) 62%, var(--color-ink));
	}

	.infogerance-strip:hover {
		border-color: var(--strip-accent);
		background: color-mix(in srgb, var(--strip-accent) 4%, white);
		box-shadow: 0 12px 30px color-mix(in srgb, var(--strip-accent) 7%, transparent);
	}
</style>
