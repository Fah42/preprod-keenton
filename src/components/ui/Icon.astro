---
// Jeu d'icones outline du site (style ligne, inspire de la maquette).
// Usage : <Icon name="cloud" class="h-6 w-6 text-accent" />
import { icons } from '../../data/icons.js';

const { name, class: className = '' } = Astro.props;
---

<svg
	class={className}
	viewBox="0 0 24 24"
	fill="none"
	stroke="currentColor"
	stroke-width="1.7"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
	set:html={icons[name] ?? ''}
/>
