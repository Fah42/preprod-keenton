---
// Route dynamique unique pour les 7 pages categorie -- LE template, pas 7
// fichiers separes. Contenu dans src/content/services/*.json (schema dans
// content.config.mjs). Couleur d'accent propre a chaque categorie injectee
// en CSS custom property --cat-accent sur le wrapper de page (Tailwind 4 ne
// detecte que des classes litterales comme text-[var(--cat-accent)], jamais
// une classe construite dynamiquement en JS -- cf. CLAUDE.md).
import { getCollection } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryHero from '../../components/sections/CategoryHero.astro';
import ServiceBlock from '../../components/services/ServiceBlock.astro';
import InfogeranceStrip from '../../components/sections/InfogeranceStrip.astro';
import RelatedPosts from '../../components/blog/RelatedPosts.astro';
import CTASection from '../../components/sections/CTASection.astro';

import { finalCta } from '../../data/home.js';
import { expertises } from '../../data/site.js';

export async function getStaticPaths() {
	const entries = await getCollection('services');
	return entries.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { description, hero, sections } = entry.data;
const category = expertises.find((e) => e.slug === entry.id);

const relatedPosts = (await getCollection('blog', ({ data }) => !data.draft && data.expertise === entry.id))
	.sort((a, b) => b.data.date - a.data.date)
	.slice(0, 3);
---


<BaseLayout title={`${category?.title} | Keenton`} description={description}>
	<div class:list={[
		'expertise-page',
		entry.id === 'informatique-entreprise' && 'expertise-page--infrastructure',
		entry.id === 'infogerance' && 'expertise-page--infogerance',
		entry.id === 'devops' && 'expertise-page--devops',
		entry.id === 'hebergement-cloud' && 'expertise-page--hebergement-cloud',
		entry.id === 'cybersecurite' && 'expertise-page--cybersecurite',
		entry.id === 'automatisation-ia' && 'expertise-page--automatisation-ia',
	]} style={`--cat-accent: ${category?.accentColor}`}>
		<CategoryHero {...hero} icon={category?.icon} />
		{entry.id !== 'infogerance' && <InfogeranceStrip />}

		<div id="sections">
			{sections.map((section, i) => <ServiceBlock {...section} reverse={i % 2 === 1} />)}
		</div>

		<RelatedPosts posts={relatedPosts} />
	</div>

	<CTASection {...finalCta} />
</BaseLayout>

<style is:global>
	/* Moitie du rythme initial py-16/md:py-24 : 32 px puis 48 px. */
	.expertise-page .service-block > section {
		padding-block: 2rem;
	}

	@media (min-width: 48rem) {
		.expertise-page .service-block > section {
			padding-block: 3rem;
		}
	}

	.expertise-page[class*='expertise-page--'] #sections {
		background:
			radial-gradient(circle at 88% 12%, color-mix(in srgb, var(--cat-accent) 3.5%, transparent), transparent 24%),
			linear-gradient(to bottom, color-mix(in srgb, var(--cat-accent) 2.5%, white), transparent 18%);
	}

	.expertise-page[class*='expertise-page--'] .service-block {
		border-color: color-mix(in srgb, var(--cat-accent) 18%, transparent);
	}

	.expertise-page[class*='expertise-page--'] .service-block[data-service-type='capabilities'] section {
		background: linear-gradient(135deg, color-mix(in srgb, var(--cat-accent) 7%, white), white 54%);
	}

	.expertise-page[class*='expertise-page--'] .service-block[data-service-type='mosaic'] section {
		background: linear-gradient(145deg, color-mix(in srgb, var(--cat-accent) 5%, white), color-mix(in srgb, var(--cat-accent) 10%, white));
	}

	.expertise-page[class*='expertise-page--'] .service-block[data-service-type='mosaic'] article {
		border-color: color-mix(in srgb, var(--cat-accent) 42%, var(--color-line));
		box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--cat-accent) 8%, transparent), 0 12px 30px rgb(10 16 27 / 0.045);
	}

	.expertise-page[class*='expertise-page--'] .service-block[data-service-type='mosaic'] article:hover {
		background: color-mix(in srgb, var(--cat-accent) 5%, white);
		box-shadow: inset 0 0 0 1px var(--cat-accent), 0 16px 36px color-mix(in srgb, var(--cat-accent) 7.5%, transparent);
	}

	.expertise-page[class*='expertise-page--'] .service-block[data-service-type='split'] section {
		background: linear-gradient(135deg, white, color-mix(in srgb, var(--cat-accent) 4%, white));
	}

	.expertise-page[class*='expertise-page--'] .service-block article {
		border-color: color-mix(in srgb, var(--cat-accent) 18%, var(--color-line));
		box-shadow: 0 12px 30px rgb(10 16 27 / 0.045);
	}

	.expertise-page[class*='expertise-page--'] .service-block[data-service-type='capabilities'] article:hover {
		border-color: var(--cat-accent);
		transform: translateY(-0.25rem);
		background: color-mix(in srgb, var(--cat-accent) 5%, white);
		box-shadow: inset 0 0 0 1px var(--cat-accent), 0 16px 36px color-mix(in srgb, var(--cat-accent) 7.5%, transparent);
	}

	.expertise-page[class*='expertise-page--'] .service-block[data-service-type='capabilities'] article {
		transition: transform 200ms ease, border-color 200ms ease, background-color 200ms ease, box-shadow 200ms ease;
	}

	.expertise-page[class*='expertise-page--'] .service-block:nth-child(1) section {
		background: linear-gradient(120deg, white 0%, color-mix(in srgb, var(--cat-accent) 6%, white) 100%);
	}

	.expertise-page[class*='expertise-page--'] .service-block:nth-child(2) section {
		background: linear-gradient(145deg, color-mix(in srgb, var(--cat-accent) 11%, white), color-mix(in srgb, var(--cat-accent) 4%, white));
	}

	.expertise-page[class*='expertise-page--'] .service-block:nth-child(3) section {
		background-color: white;
		background-image:
			linear-gradient(to right, color-mix(in srgb, var(--cat-accent) 5%, transparent) 1px, transparent 1px),
			linear-gradient(to bottom, color-mix(in srgb, var(--cat-accent) 5%, transparent) 1px, transparent 1px);
		background-size: 2rem 2rem;
	}

	.expertise-page[class*='expertise-page--'] .service-block:nth-child(4) section {
		background: linear-gradient(120deg, color-mix(in srgb, var(--cat-accent) 4%, white), white 62%);
	}
</style>
